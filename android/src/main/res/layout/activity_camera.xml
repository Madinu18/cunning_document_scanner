<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <!-- Preview + overlay are resized to the capture aspect ratio in code and
         centered vertically, so the framing guide maps 1:1 onto the photo. -->
    <androidx.camera.view.PreviewView
        android:id="@+id/preview_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center" />

    <biz.cunning.cunning_document_scanner.fallback.ui.GuideOverlayView
        android:id="@+id/guide_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center" />

    <TextView
        android:id="@+id/guide_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="48dp"
        android:paddingHorizontal="14dp"
        android:paddingVertical="6dp"
        android:background="#80000000"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:text="Posisikan dokumen di dalam bingkai" />

    <ImageButton
        android:id="@+id/close_button"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="top|start"
        android:layout_margin="16dp"
        android:background="@android:color/transparent"
        android:src="@drawable/ic_baseline_arrow_back_24"
        android:tint="#FFFFFF"
        android:contentDescription="Tutup" />

    <ImageButton
        android:id="@+id/shutter_button"
        android:layout_width="76dp"
        android:layout_height="76dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="40dp"
        android:background="@drawable/shutter_button"
        android:contentDescription="Ambil foto" />

</FrameLayout>
